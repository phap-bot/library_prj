# SmartLib Kiosk - Environment Configuration
# Copy to .env and fill in values

# ===========================================
# APPLICATION SETTINGS
# ===========================================
APP_NAME=SmartLib Kiosk
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# ===========================================
# DATABASE (REQUIRED)
# ===========================================
# Supabase PostgreSQL - using direct connection for asyncpg
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://your-user:your-password@your-host:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# ===========================================
# CORS SETTINGS
# ===========================================
# Comma-separated list of allowed origins
# Example: http://localhost:5173,https://yourdomain.com
# Use * for development (not recommended for production)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ===========================================
# AI MODELS CONFIGURATION
# ===========================================
FACE_MODEL_PATH=models/face_recognition/arcface_r100.onnx
ANTISPOOFING_MODEL_PATH=models/anti_spoofing/minifasnet.onnx
YOLO_MODEL_PATH=models/book_detection/yolov8m_books.pt
OCR_LANG=vi

# ===========================================
# FACE RECOGNITION THRESHOLDS
# ===========================================
# Similarity threshold for face matching (0.5-0.7 recommended)
FACE_SIMILARITY_THRESHOLD=0.6
# Liveness detection threshold
LIVENESS_THRESHOLD=0.5

# ===========================================
# BOOK DETECTION
# ===========================================
BOOK_DETECTION_CONFIDENCE=0.5

# ===========================================
# TRANSACTION SETTINGS
# ===========================================
MAX_BORROW_DAYS=14
FINE_PER_DAY=10000
MAX_BOOKS_PER_STUDENT=5

# ===========================================
# SERVER
# ===========================================
HOST=0.0.0.0
PORT=8000
